<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- #region 通用 -->

    <!-- Focus Visual -->
    <Color x:Key="FocusVisualColor">#60000000</Color>
    <!-- Foreground -->
    <Color x:Key="ForegroundColor">#F7F7F7</Color>
    <Color x:Key="HoverForegroundColor">#F7F7F7</Color>
    <Color x:Key="PressedForegroundColor">#F7F7F7</Color>
    <Color x:Key="DefaultedForegroundColor">#F7F7F7</Color>
    <Color x:Key="DisabledForegroundColor">#888888</Color>
    <Color x:Key="HighlightedForegroundColor">#FFFFFF</Color>
    <!-- Background -->
    <Color x:Key="BackgroundColor">#2F2F2F</Color>
    <Color x:Key="HoverBackgroundColor">#353535</Color>
    <Color x:Key="PressedBackgroundColor">#3A3A3A</Color>
    <Color x:Key="DefaultedBackgroundColor">#2F2F2F</Color>
    <Color x:Key="DisabledBackgroundColor">#3A3A3A</Color>
    <Color x:Key="HighlightedBackgroundColor">#4D4D4D</Color>
    <!-- Border -->
    <Color x:Key="BorderColor">#4C4C4C</Color>
    <Color x:Key="HoverBorderColor">#AAAAAA</Color>
    <Color x:Key="PressedBorderColor">#5D5D5D</Color>
    <Color x:Key="DefaultedBorderColor">#888888</Color>
    <Color x:Key="DisabledBorderColor">#5D5D5D</Color>

    <!-- #endregion 通用 -->

    <!-- #region Window -->

    <Color x:Key="WindowBackgroundColor">#191919</Color>
    <Color x:Key="WindowBorderColor">#313734</Color>
    <Color x:Key="TitleBarForegroundColor">#A3A3A3</Color>
    <Color x:Key="TitleBarBackgroundColor">#191919</Color>
    <Color x:Key="TitleBarButtonForegroundColor">#A3A3A3</Color>
    <Color x:Key="TitleBarButtonBackgroundColor">Transparent</Color>
    <Color x:Key="TitleBarButtonHoverBackgroundColor">#242424</Color>
    <Color x:Key="TitleBarButtonPressedBackgroundColor">#303030</Color>
    <Color x:Key="TitleBarCloseButtonHoverPressedForegroundColor">#FFFFFF</Color>
    <Color x:Key="TitleBarCloseButtonHoverBackgroundColor">#FA5959</Color>
    <Color x:Key="TitleBarCloseButtonPressedBackgroundColor">#FA6262</Color>

    <!-- #endregion Window -->

</ResourceDictionary>