										<ColorAnimation Storyboard.TargetName="Border" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="{StaticResource HoverBorderColor}" Duration="0:0:0.2" />
										<!-- 文字颜色渐变 -->
										<ColorAnimation Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)" To="{StaticResource HoverForegroundColor}" Duration="0:0:0.2" />
										<!-- 上浮 1px -->
										<DoubleAnimation Storyboard.TargetName="TranslateTransform" Storyboard.TargetProperty="Y" To="-1" Duration="0:0:0.15" FillBehavior="HoldEnd" />
										<!-- 添加阴影 -->
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="Border" Storyboard.TargetProperty="Effect">
											<DiscreteObjectKeyFrame KeyTime="0:0:0">
												<DiscreteObjectKeyFrame.Value>
													<DropShadowEffect Color="{StaticResource HoverBorderColor}" ShadowDepth="2" BlurRadius="8" Opacity="0.3" />
												</DiscreteObjectKeyFrame.Value>
											</DiscreteObjectKeyFrame>
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</BeginStoryboard>
							</MultiDataTrigger.EnterActions>
							<MultiDataTrigger.ExitActions>
								<BeginStoryboard>
									<Storyboard>
										<!-- 恢复背景 -->
										<ColorAnimation Storyboard.TargetName="Border" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="{StaticResource DefaultedBackgroundColor}" Duration="0:0:0.2" />
										<!-- 恢复边框 -->
										<ColorAnimation Storyboard.TargetName="Border" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="{StaticResource DefaultedBorderColor}" Duration="0:0:0.2" />
										<!-- 恢复文字 -->
										<ColorAnimation Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)" To="{StaticResource DefaultedForegroundColor}" Duration="0:0:0.2" />
										<DoubleAnimation Storyboard.TargetName="TranslateTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.15" />
										<ObjectAnimationUsingKeyFrames Storyboard.TargetName="Border" Storyboard.TargetProperty="Effect">
											<DiscreteObjectKeyFrame KeyTime="0:0:0">
												<DiscreteObjectKeyFrame.Value>
													<x:Null />
												</DiscreteObjectKeyFrame.Value>
											</DiscreteObjectKeyFrame>
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</BeginStoryboard>
							</MultiDataTrigger.ExitActions>
						</MultiDataTrigger>
						<!-- 未启用鼠标悬停动画 且 未按下 -->
						<MultiDataTrigger>
							<MultiDataTrigger.Conditions>
								<Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
								<Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="False" />
								<Condition Binding="{Binding Path=(tools:VisualHelper.IsVisualStateAnimated), RelativeSource={RelativeSource Self}}" Value="False" />
							</MultiDataTrigger.Conditions>
							<Setter Property="Foreground" Value="{DynamicResource HoverForegroundBrush}" />
							<Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
							<Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource HoverBorderBrush}" />
						</MultiDataTrigger>
						<!-- 未启用鼠标悬停动画 且 按下 -->
						<MultiDataTrigger>
							<MultiDataTrigger.Conditions>
								<Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
								<Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True" />
								<Condition Binding="{Binding Path=(tools:VisualHelper.IsVisualStateAnimated), RelativeSource={RelativeSource Self}}" Value="False" />
							</MultiDataTrigger.Conditions>
							<Setter Property="Foreground" Value="{DynamicResource PressedForegroundBrush}" />
							<Setter TargetName="Border" Property="Background" Value="{DynamicResource PressedBackgroundBrush}" />
							<Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PressedBorderBrush}" />
						</MultiDataTrigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
