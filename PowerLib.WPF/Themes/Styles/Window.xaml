<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:o="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:pl="clr-namespace:PowerLib.WPF.Controls"
                    xmlns:converter="clr-namespace:PowerLib.WPF.Tools.Converters">

    <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <converter:WindowContentPresenterMarginConverter x:Key="WindowContentPresenterMarginConverter" />
    <converter:WindowCornerRadiusConverter x:Key="WindowCornerRadiusConverter" />
    <converter:WindowTitleBarCornerRadiusConverter x:Key="WindowTitleBarCornerRadiusConverter" />
    <converter:WindowTitleBarMarginConverter x:Key="WindowTitleBarMarginConverter" />
    <converter:WindowShadowBlurRadiusConverter x:Key="WindowShadowBlurRadiusConverter" />
    <converter:WindowClipRectConverter x:Key="WindowClipRectConverter" />
    <converter:WindowResizeBorderThicknessConverter x:Key="WindowResizeBorderThicknessConverter" />
    <converter:WindowCloseButtonCornerRadiusConverter x:Key="WindowCloseButtonCornerRadiusConverter" />
    <converter:WindowIconVisibilityConverter x:Key="WindowIconVisibilityConverter" />
    <converter:WindowShadowOpacityConverter x:Key="WindowShadowOpacityConverter" />

    <Geometry o:Freeze="True" x:Key="WindowMinGeometry">M0,4 L10,4 L10,5 L0,5 z</Geometry>
    <Geometry o:Freeze="True" x:Key="WindowRestoreGeometry">M1,3 L1,9 L7,9 L7,3 z M3,1 L3,2 L8,2 L8,7 L9,7 L9,1 z M2,0 L10,0 L10,8 L8,8 L8,10 L0,10 L0,2 L2,2 z</Geometry>
    <Geometry o:Freeze="True" x:Key="WindowMaxGeometry">M1,1 L1,9 L9,9 L9,1 z M0,0 L10,0 L10,10 L0,10 z</Geometry>
    <Geometry o:Freeze="True" x:Key="WindowCloseGeometry">M0.7,0 L5,4.3 L9.3,0 L10,0.7 L5.7,5 L10,9.3 L9.3,10 L5,5.7 L0.7,10 L0,9.3 L4.3,5 L0,0.7 z</Geometry>

    <!-- 窗口按钮样式 -->
    <Style x:Key="DefaultWindowButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="45"/>
        <Setter Property="Height" Value="{Binding TitleBarHeight,RelativeSource={RelativeSource AncestorType=pl:Window}}"/>
        <Setter Property="Foreground" Value="{DynamicResource TitleBarButtonForegroundBrush}"/>
        <Setter Property="Background" Value="{DynamicResource TitleBarButtonBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource TitleBarButtonHoverBackgroundBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource TitleBarButtonPressedBackgroundBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="DefaultMinimizeButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultWindowButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <Path Data="{StaticResource WindowMinGeometry}" Fill="{TemplateBinding Foreground}" Stretch="Uniform" Width="10"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="DefaultMaximizeButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultWindowButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <Path x:Name="MaximizePath" Data="{StaticResource WindowMaxGeometry}" Fill="{TemplateBinding Foreground}" Stretch="Uniform" Width="10"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                            <Setter TargetName="MaximizePath" Property="Data" Value="{StaticResource WindowRestoreGeometry}"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="DefaultCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultWindowButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=pl:Window}, Converter={StaticResource WindowCloseButtonCornerRadiusConverter}}">
                        <Path Data="{StaticResource WindowCloseGeometry}" Fill="{TemplateBinding Foreground}" Stretch="Uniform" Width="10"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource TitleBarCloseButtonHoverBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TitleBarCloseButtonHoverPressedForegroundBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource TitleBarCloseButtonPressedBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TitleBarCloseButtonHoverPressedForegroundBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 窗口样式 -->
    <Style TargetType="{x:Type pl:Window}">
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome GlassFrameThickness="0"
                              CaptionHeight="0" 
                              ResizeBorderThickness="{Binding ShadowWidth, RelativeSource={RelativeSource AncestorType=pl:Window}, Converter={StaticResource WindowResizeBorderThicknessConverter}}"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="Window.Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type pl:Window}">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <!-- 窗口阴影和边框 -->
                        <Border x:Name="PART_ShadowAndBorder"
                                IsHitTestVisible="False"
                                Margin="{Binding ShadowWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                BorderThickness="{Binding BorderWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                BorderBrush="{DynamicResource WindowBorderBrush}"
                                Background="{DynamicResource WindowBackgroundBrush}"
                                CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource WindowCornerRadiusConverter}}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="{Binding ShadowWidth, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource WindowShadowBlurRadiusConverter}}">
                                    <DropShadowEffect.Opacity>
                                        <MultiBinding Converter="{StaticResource WindowShadowOpacityConverter}">
                                            <Binding Path="ShowShadow" RelativeSource="{RelativeSource TemplatedParent}" />
                                            <Binding Path="ShadowOpacity" RelativeSource="{RelativeSource TemplatedParent}" />
                                        </MultiBinding>
                                    </DropShadowEffect.Opacity>
                                </DropShadowEffect>
                            </Border.Effect>
                        </Border>
                        <!-- 窗口实际区域，包含标题栏和客户区 -->
                        <Grid x:Name="WindowInner">
                            <!-- 标题栏 -->
                            <Border x:Name="PART_TitleBar"
                                    Visibility="{Binding ShowTitleBar, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource WindowTitleBarCornerRadiusConverter}}" 
                                    Background="{DynamicResource TitleBarBackgroundBrush}"
                                    Height="{TemplateBinding TitleBarHeight}" 
                                    VerticalAlignment="Top">
                                <Border.Margin>
                                    <MultiBinding Converter="{StaticResource WindowTitleBarMarginConverter}">
                                        <Binding Path="ShadowWidth" RelativeSource="{RelativeSource AncestorType=pl:Window}" />
                                        <Binding Path="BorderWidth" RelativeSource="{RelativeSource AncestorType=pl:Window}" />
                                    </MultiBinding>
                                </Border.Margin>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <DockPanel Grid.Column="0" LastChildFill="True" Margin="0">
                                        <Image IsHitTestVisible="False" 
                                               Source="{TemplateBinding Icon}"
                                               VerticalAlignment="Center"
                                               Width="16"
                                               Height="16"
                                               Margin="10,0,0,0"
                                               Visibility="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource WindowIconVisibilityConverter}}"/>
                                        <TextBlock Text="{TemplateBinding Title}"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TitleBarForegroundBrush}"/>
                                    </DockPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0">
                                        <Button x:Name="PART_MinimizeButton"
                                                Style="{DynamicResource DefaultMinimizeButtonStyle}"
                                                Visibility="{Binding ShowMinButton, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Button x:Name="PART_MaxRestoreButton"
                                                Style="{DynamicResource DefaultMaximizeButtonStyle}"
                                                Visibility="{Binding ShowMaxButton, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button x:Name="PART_CloseButton"
                                                Style="{DynamicResource DefaultCloseButtonStyle}"
                                                Visibility="{Binding ShowCloseButton, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <!-- 客户区 -->
                            <AdornerDecorator Margin="0,0,0,0">
                                <ContentPresenter ClipToBounds="True" x:Name="PART_ContentPresenter">
                                    <ContentPresenter.Margin>
                                        <MultiBinding Converter="{StaticResource WindowContentPresenterMarginConverter}">
                                            <Binding Path="ShadowWidth" RelativeSource="{RelativeSource AncestorType=pl:Window}" />
                                            <Binding Path="BorderWidth" RelativeSource="{RelativeSource AncestorType=pl:Window}" />
                                            <Binding Path="ShowTitleBar" RelativeSource="{RelativeSource AncestorType=pl:Window}" />
                                            <Binding Path="TitleBarHeight" RelativeSource="{RelativeSource AncestorType=pl:Window}" />
                                        </MultiBinding>
                                    </ContentPresenter.Margin>
                                </ContentPresenter>
                            </AdornerDecorator>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>