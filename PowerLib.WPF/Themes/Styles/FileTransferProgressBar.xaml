<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:pl="clr-namespace:PowerLib.WPF.Controls">
    <Style TargetType="{x:Type pl:FileTransferProgressBar}">
        <Setter Property="Width" Value="400" />
        <Setter Property="Height" Value="80" />
        <Setter Property="FontFamily" Value="Microsoft YaHei" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}" />
        <Setter Property="GridBrush" Value="#FFCDEFD3" />
        <Setter Property="SpeedForeground" Value="#FF06B025" />
        <Setter Property="SpeedBackground" Value="#FFA7E591" />
        <Setter Property="SpeedTextBrush" Value="{DynamicResource ForegroundBrush}" />
    </Style>
</ResourceDictionary>
